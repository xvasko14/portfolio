---
import BaseLayout from "./BaseLayout.astro";
import ProjectMeta from "../components/projects/ProjectMeta.astro";
import type { ProjectData } from "../components/projects/project-collection";

interface Props extends Pick<ProjectData, "title" | "summary" | "year" | "tags" | "status"> {}

const { title, summary, year, tags, status } = Astro.props;
---

<BaseLayout title={title} description={summary}>
  <section class="section project-hero">
    <div class="container project-hero__grid">
      <div class="content-width">
        <p class="section-intro__eyebrow">Project</p>
        <h1>{title}</h1>
        <p class="project-hero__summary">{summary}</p>
      </div>

      <ProjectMeta year={year} tags={tags} status={status} />
    </div>
  </section>

  <section class="section project-body">
    <div class="container project-body__grid">
      <article class="project-content prose">
        <slot />
      </article>

      <aside class="project-nav" aria-label="Project navigation">
        <p class="project-nav__label">Next step</p>
        <a class="project-nav__link" href="/projects">Browse all projects</a>
        <p class="project-nav__copy">
          More case studies will appear here as they are written up with enough detail to be useful.
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>
