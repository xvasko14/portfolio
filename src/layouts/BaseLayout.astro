---
import globalStylesHref from "../styles/global.css?url";
import { site } from "../data/site";
import Header from "../components/site/Header.astro";
import MenuOverlay from "../components/site/MenuOverlay.astro";
import Footer from "../components/site/Footer.astro";
import menuScriptHref from "../scripts/menu.ts?url";
import revealScriptHref from "../scripts/reveal.ts?url";

interface Props {
  description?: string;
  title?: string;
}

const { description = site.description, title = site.title } = Astro.props;
const pageTitle = title === site.title ? title : `${title} | ${site.title}`;
const canonicalUrl = new URL(Astro.url.pathname, site.url).href;
const ogImageUrl = new URL(site.assets.ogImage, site.url).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07111f" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={site.assets.favicon} type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preload" href={globalStylesHref} as="style" />
    <link rel="stylesheet" href={globalStylesHref} />
  </head>
  <body>
    <div class="site-shell">
      <MenuOverlay />
      <div data-menu-content>
        <Header />

        <main>
          <slot />
        </main>

        <Footer />
      </div>
    </div>

    <script type="module" src={menuScriptHref}></script>
    <script type="module" src={revealScriptHref}></script>
  </body>
</html>
