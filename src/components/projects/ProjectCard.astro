---
import type { ProjectData } from "./project-collection";

interface Props extends Pick<ProjectData, "title" | "summary" | "year" | "tags" | "status"> {
  href: string;
}

const { href, title, summary, year, tags, status } = Astro.props;
---

<a class="project-card" href={href}>
  <div class="project-card__header">
    <p class="project-card__eyebrow">{status.replace("-", " ")}</p>
    <span class="project-card__year">{year}</span>
  </div>

  <h2>{title}</h2>
  <p>{summary}</p>

  <ul class="project-card__tags" aria-label="Project tags">
    {tags.map((tag) => <li>{tag}</li>)}
  </ul>
</a>
