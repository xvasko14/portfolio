---
import ButtonLink from "../ui/ButtonLink.astro";
import { site } from "../../data/site";
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div>
      <a class="site-brand" href="/">
        <strong>{site.title}</strong>
        <span>{site.role}</span>
      </a>
    </div>

    <div class="site-footer__content">
      <ul class="site-footer__socials" aria-label="Footer social links">
        {site.socials.map((item) => (
          <li>
            <ButtonLink href={item.href} target="_blank" rel="noreferrer" variant="ghost">
              {item.label}
            </ButtonLink>
          </li>
        ))}
      </ul>

      <ButtonLink href={site.contact.email.href} variant="ghost">{site.contact.email.label}</ButtonLink>
    </div>
  </div>
</footer>
