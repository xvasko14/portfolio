---
import ButtonLink from "../ui/ButtonLink.astro";
import { site } from "../../data/site";

const isProvisionalContact = site.contact.status === "provisional";
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div>
      <a class="site-brand" href="/">
        <strong>{site.title}</strong>
        <span>{site.role}</span>
      </a>
    </div>

    <div class="site-footer__content">
      <ul class="site-footer__socials" aria-label={isProvisionalContact ? "Provisional social links" : "Footer social links"}>
        {site.socials.map((item) => (
          <li>
            <ButtonLink href={item.href} target="_blank" rel="noreferrer" variant="ghost">
              {isProvisionalContact ? `${item.label} (placeholder)` : item.label}
            </ButtonLink>
          </li>
        ))}
      </ul>

      <div class="site-footer__contact-note">
        <ButtonLink href={site.contact.email.href} variant="ghost">
          {isProvisionalContact ? `${site.contact.email.label} (placeholder)` : site.contact.email.label}
        </ButtonLink>
        {isProvisionalContact ? <p class="site-footer__note">{site.contact.note}</p> : null}
      </div>
    </div>
  </div>
</footer>
