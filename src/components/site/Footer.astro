---
import { site } from "../../data/site";

const email = site.socials.find((item) => item.href.startsWith("mailto:"));
const socials = site.socials.filter((item) => !item.href.startsWith("mailto:"));
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div>
      <a class="site-brand" href="/">
        <strong>{site.title}</strong>
        <span>{site.role}</span>
      </a>
    </div>

    <div class="site-footer__content">
      <ul class="site-footer__socials" aria-label="Footer social links">
        {socials.map((item) => (
          <li><a href={item.href} target="_blank" rel="noreferrer">{item.label}</a></li>
        ))}
      </ul>

      {email ? (
        <a class="site-footer__email" href={email.href}>
          {email.href.replace("mailto:", "")}
        </a>
      ) : null}
    </div>
  </div>
</footer>
