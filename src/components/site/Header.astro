---
import { site } from "../../data/site";

const pathname = Astro.url.pathname;

const isActivePath = (href: string) => {
  if (href === "/") {
    return pathname === "/";
  }

  return pathname === href || pathname.startsWith(`${href}/`);
};
---

<header class="site-header" data-site-header data-header-state="top">
  <div class="container site-header__inner">
    <a class="site-brand" href="/">
      <strong>{site.title}</strong>
      <span>{site.role}</span>
    </a>

    <nav class="site-header__nav" aria-label="Primary" data-header-top-nav data-nav-indicator-root="header">
      <ul class="site-header__nav-list">
        {site.navigation.map((item) => {
          const active = isActivePath(item.href);

          return (
            <li>
              <a
                href={item.href}
                class:list={{ "site-header__nav-link": true, "is-active": active }}
                data-nav-link
                data-nav-indicator-link
                data-nav-active={active ? "true" : "false"}
                aria-current={active ? "page" : undefined}
              >
                <span class="site-header__nav-dot" aria-hidden="true"></span>
                <span>{item.label}</span>
              </a>
            </li>
          );
        })}
      </ul>
      <span class="site-header__nav-indicator" aria-hidden="true" data-nav-indicator></span>
    </nav>

    <button
      class="site-header__trigger"
      type="button"
      aria-controls="site-menu"
      aria-expanded="false"
      aria-label="Open menu"
      data-header-menu-trigger
      data-menu-open
    >
      <span class="site-header__trigger-icon" aria-hidden="true"></span>
    </button>
  </div>
</header>
