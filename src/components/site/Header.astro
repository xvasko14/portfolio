---
import { site } from "../../data/site";

const pathname = Astro.url.pathname;

const isActivePath = (href: string) => {
  if (href === "/") {
    return pathname === "/";
  }

  return pathname === href || pathname.startsWith(`${href}/`);
};
---

<header class="site-header" data-site-header data-header-state="top">
  <div class="container site-header__inner">
    <a class="site-brand" href="/">
      <strong>{site.title}</strong>
      <span>{site.role}</span>
    </a>

    <nav class="site-header__nav" aria-label="Primary" data-header-top-nav>
      <ul class="site-header__nav-list">
        {site.navigation.map((item) => {
          const active = isActivePath(item.href);

          return (
            <li>
              <a
                href={item.href}
                class:list={{ "site-header__nav-link": true, "is-active": active }}
                data-nav-link
                data-nav-active={active ? "true" : "false"}
                aria-current={active ? "page" : undefined}
              >
                <span class="site-header__nav-dot" aria-hidden="true"></span>
                <span>{item.label}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <button
      class="site-header__trigger"
      type="button"
      aria-controls="site-menu"
      aria-expanded="false"
      aria-label="Open menu"
      data-header-menu-trigger
      data-menu-open
    >
      Menu
    </button>
  </div>
</header>

<script is:inline>
  const header = document.querySelector("[data-site-header]");

  if (header) {
    const topNav = header.querySelector("[data-header-top-nav]");
    const trigger = header.querySelector("[data-header-menu-trigger]");
    const desktopQuery = window.matchMedia("(min-width: 721px)");
    const scrolledOffset = 24;

    const syncHeaderState = () => {
      if (!topNav || !trigger) {
        return;
      }

      const state = desktopQuery.matches
        ? window.scrollY > scrolledOffset
          ? "scrolled"
          : "top"
        : "mobile";

      header.dataset.headerState = state;
    };

    syncHeaderState();
    window.addEventListener("scroll", syncHeaderState, { passive: true });
    window.addEventListener("resize", syncHeaderState);

    if (typeof desktopQuery.addEventListener === "function") {
      desktopQuery.addEventListener("change", syncHeaderState);
    }
  }
</script>

<style>
  .site-header__nav {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .site-header__nav-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: clamp(1rem, 2vw, 1.8rem);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-header__nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: color-mix(in srgb, var(--text) 88%, var(--muted));
    font-size: 0.98rem;
    letter-spacing: 0.01em;
    transition:
      color 180ms ease,
      opacity 180ms ease,
      transform 180ms ease;
  }

  .site-header__nav-link:hover,
  .site-header__nav-link:focus-visible {
    color: var(--text);
    transform: translateY(-1px);
  }

  .site-header__nav-link[aria-current="page"] {
    color: var(--text);
  }

  .site-header__nav-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: currentColor;
    opacity: 0;
    transform: scale(0.5);
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  .site-header__nav-link[aria-current="page"] .site-header__nav-dot {
    opacity: 1;
    transform: scale(1);
  }

  .site-header__trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.2rem;
    height: 3.2rem;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    color: inherit;
    font: inherit;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .site-header__trigger:hover,
  .site-header__trigger:focus-visible {
    border-color: color-mix(in srgb, var(--accent) 50%, var(--border));
    background: var(--accent-soft);
    box-shadow: 0 0.8rem 2rem rgba(3, 10, 22, 0.28);
    transform: translateY(-1px);
  }

  .site-header[data-header-state="top"] .site-header__nav {
    display: flex;
  }

  .site-header[data-header-state="top"] .site-header__trigger {
    display: none;
  }

  .site-header[data-header-state="scrolled"] .site-header__nav,
  .site-header[data-header-state="mobile"] .site-header__nav {
    display: none;
  }

  .site-header[data-header-state="scrolled"] .site-header__trigger,
  .site-header[data-header-state="mobile"] .site-header__trigger {
    display: inline-flex;
  }

  @media (max-width: 720px) {
    .site-header__nav-list {
      gap: 1rem;
    }
  }
</style>
