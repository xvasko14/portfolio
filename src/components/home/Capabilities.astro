---
import Section from "../ui/Section.astro";
import SectionIntro from "../ui/SectionIntro.astro";
import { home } from "../../data/home";
---

<Section class="home-capabilities" id="capabilities">
  <SectionIntro eyebrow={home.capabilitiesSection.eyebrow} title={home.capabilitiesSection.title}>
    <p>{home.capabilitiesSection.body}</p>
  </SectionIntro>

  <div class="capability-grid">
    {home.capabilities.map((item, index) => (
      <article
        class="capability-card"
        data-reveal
        style={`--reveal-delay: ${index * 90}ms;`}
      >
        <p class="capability-card__kicker">{item.eyebrow}</p>
        <h3>{item.title}</h3>
        <p>{item.detail}</p>
      </article>
    ))}
  </div>
</Section>
