---
import Section from "../ui/Section.astro";
import SectionIntro from "../ui/SectionIntro.astro";
import { home } from "../../data/home";
---

<Section class="home-capabilities" id="capabilities">
  <SectionIntro eyebrow="Capabilities" title="What I work on">
    <p>Core areas where I help teams make delivery and operations more dependable.</p>
  </SectionIntro>

  <div class="capability-grid">
    {home.capabilities.map((item) => (
      <article class="capability-card">
        <p class="capability-card__kicker">{item.title}</p>
        <h3>{item.description}</h3>
        <p>{item.detail}</p>
      </article>
    ))}
  </div>
</Section>
