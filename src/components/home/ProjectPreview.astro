---
import { getSortedProjects } from "../projects/project-collection";
import Section from "../ui/Section.astro";
import SectionIntro from "../ui/SectionIntro.astro";
import ButtonLink from "../ui/ButtonLink.astro";
import { home } from "../../data/home";

const projects = (await getSortedProjects()).slice(0, 3);
---

<Section class="home-projects" id="projects-preview">
  <SectionIntro eyebrow={home.projects.eyebrow} title={home.projects.title}>
    <p>{home.projects.body}</p>
  </SectionIntro>

  <div class="project-preview-grid">
    {projects.map((project, index) => (
      <article
        class="project-preview-card"
        data-reveal
        style={`--reveal-delay: ${index * 100}ms;`}
      >
        <h3>{project.data.title}</h3>
        <p>{project.data.summary}</p>
        <p class="project-preview-card__outcome">
          {project.data.status === "in-progress"
            ? "Current status: actively being shaped into a fuller write-up."
            : `Current status: ${project.data.status}.`}
        </p>
      </article>
    ))}
  </div>

  <div class="project-preview__actions">
    <ButtonLink href={home.projects.footerCta.href} variant="ghost">
      {home.projects.footerCta.label}
    </ButtonLink>
  </div>
</Section>
