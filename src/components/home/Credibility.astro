---
import Section from "../ui/Section.astro";
import SectionIntro from "../ui/SectionIntro.astro";
import { home } from "../../data/home";
---

<Section class="home-credibility" id="credibility">
  <SectionIntro eyebrow={home.credibility.eyebrow} title={home.credibility.title}>
    <p>{home.credibility.body}</p>
  </SectionIntro>

  <div class="credibility-strip">
    {home.credibility.signals.map((item) => (
      <article class="credibility-item">
        <p class="credibility-item__label">{item.label}</p>
        <h3>{item.value}</h3>
        <p>{item.note}</p>
      </article>
    ))}
  </div>
</Section>
