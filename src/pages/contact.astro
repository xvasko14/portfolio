---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import ButtonLink from "../components/ui/ButtonLink.astro";
import { contact } from "../data/contact";
import { site } from "../data/site";
---

<BaseLayout title="Contact" description="Contact Vasko Michal by email, GitHub, or LinkedIn.">
  <Section class="page-hero">
    <div class="content-width">
      <p class="section-intro__eyebrow">{contact.hero.eyebrow}</p>
      <h1>{contact.hero.title}</h1>
      <p class="page-hero__lead">{contact.hero.body}</p>
    </div>
  </Section>

  <Section class="contact-page">
    <div class="contact-card">
      <p class="contact-card__availability">{contact.availability}</p>

      <div class="contact-actions" aria-label="Contact links">
        <ButtonLink href={site.contact.email.href}>{site.contact.email.label}</ButtonLink>
        <ButtonLink href={site.contact.github.href} target="_blank" rel="noreferrer" variant="ghost">
          {site.contact.github.label}
        </ButtonLink>
        <ButtonLink href={site.contact.linkedin.href} target="_blank" rel="noreferrer" variant="ghost">
          {site.contact.linkedin.label}
        </ButtonLink>
      </div>
    </div>
  </Section>
</BaseLayout>
