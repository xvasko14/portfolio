---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import ButtonLink from "../components/ui/ButtonLink.astro";
import { contact } from "../data/contact";
import { site } from "../data/site";
import { mainRouteTitles } from "../data/route-intros";
---

<BaseLayout
  title="Contact"
  description="Contact Vasko Michal by LinkedIn, Instagram, Facebook, or email."
  routeIntroMode="page-title"
  routeIntroTitle={mainRouteTitles["/contact"]}
>
  <Section class="page-hero">
    <div class="content-width">
      <p class="section-intro__eyebrow">{contact.hero.eyebrow}</p>
      <h1>{contact.hero.title}</h1>
      <p class="page-hero__lead">{contact.hero.body}</p>
    </div>
  </Section>

  <Section class="contact-page">
    <div class="contact-card">
      <p class="contact-card__availability">{contact.availability}</p>

      <div class="contact-actions" aria-label="Contact links">
        <ButtonLink href={site.contact.email.href}>{site.contact.email.label}</ButtonLink>
        {site.socials.map((item) => (
          <ButtonLink href={item.href} target="_blank" rel="noreferrer" variant="ghost">
            {item.label}
          </ButtonLink>
        ))}
      </div>
    </div>
  </Section>
</BaseLayout>
