---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/projects/ProjectCard.astro";
import { getSortedProjects } from "../../components/projects/project-collection";

const projects = await getSortedProjects();
---

<BaseLayout
  title="Projects"
  description="Selected DevOps and observability work, starting with one honest project entry and room to expand."
  routeIntroMode="page-title"
  routeIntroTitle="Projects"
>
  <section class="section page-hero projects-page">
    <div class="container">
      <div class="content-width">
        <p class="section-intro__eyebrow">Projects</p>
        <h1>Projects and working notes</h1>
        <p class="page-hero__lead">
          This section is collection-backed now, but still intentionally modest. It starts with one real
          project entry instead of a padded set of case studies.
        </p>
      </div>
    </div>
  </section>

  <section class="section projects-index">
    <div class="container">
      <div class="projects-grid">
        {projects.map((project) => (
          <ProjectCard
            href={`/projects/${project.id}`}
            title={project.data.title}
            summary={project.data.summary}
            year={project.data.year}
            tags={project.data.tags}
            status={project.data.status}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
